# Sample EnvironmentFile for ca_cluster_node.service. Copy to
# /etc/default/ca_cluster_node (mode 0600 — it holds a bearer-token secret)
# on EACH of the 3 EC2 instances and fill in the per-node values below.
#
# The three nodes differ ONLY in NODE_ID, RPC_PORT/HTTP_PORT (if you choose
# not to reuse the same ports on each host's own address — reusing the
# defaults below is fine since each node lives on a different instance/IP),
# BOOTSTRAP_CA_FLAG (set on exactly one node, cluster lifetime), and which
# entry each node's own address represents inside the identical PEERS list.
# AUTH_TOKEN and the unseal passphrase at /etc/ca_cluster_node/unseal.key
# (installed separately — see ca_cluster_node.service's header) MUST be
# byte-identical on all three.
#
# Example topology (Requirement 17.11/17.12a — one node per AZ):
#   node 1 — us-east-1a — 10.0.1.10
#   node 2 — us-east-1b — 10.0.2.10
#   node 3 — us-east-1c — 10.0.3.10

# Required, differs per node: 1, 2, or 3.
NODE_ID=1

# Required, identical on all three nodes: every node's Raft RPC address (for
# consensus traffic) and client-facing HTTP address (Requirement 17.6 — used
# to build Requirement 17.7's redirect Location header), as
# <id>:<rpc_host>:<rpc_port>@<http_scheme>://<http_host>:<http_port>,
# comma-separated. Replace the example IPs with your own three instances'.
PEERS=1:10.0.1.10:7000@https://10.0.1.10:8443,2:10.0.2.10:7000@https://10.0.2.10:8443,3:10.0.3.10:7000@https://10.0.3.10:8443

# Optional, defaults shown — identical on all three nodes unless you have a
# reason to vary them.
RPC_PORT=7000
HTTP_PORT=8443

# Required, identical on all three nodes (Requirement 11.4-equivalent
# fail-closed bearer-token auth for the client-facing /v1/* API).
CA_SERVICE_AUTH_TOKEN=replace-with-a-long-random-token

# Required once fingerprint pinning is deployed alongside the token
# (Requirement 19.7) — the SHA-256 fingerprint of this node's TLS listener
# root certificate, printed at startup or via
# `ca_cluster_node --print-root-fingerprint --tls-cert ... --tls-key ...`.
# Distribute through the SAME out-of-band channel as CA_SERVICE_AUTH_TOKEN
# (this file), so a new instance's ca_bootstrap_client can pin it before
# trusting any response over TLS. --tls-cert MUST point at a full leaf+root
# chain file, not a leaf-only certificate, or there is no root in the
# presented chain for a client to pin against.
CA_CLUSTER_ROOT_FINGERPRINT=

# Set to --bootstrap-ca on EXACTLY ONE node (Requirement 17.10), empty string
# on the other two. Whichever node this is SHOULD be started first / favored
# to win the cluster's first leader election — a non-flagged node that wins
# the first election will correctly NEVER self-bootstrap (Requirement
# 17.10's "nodes started without this flag SHALL wait"), leaving the cluster
# stuck with no root material until this node eventually becomes leader.
BOOTSTRAP_CA_FLAG=--bootstrap-ca

# Rendered verbatim into ExecStart — e.g. --tls-cert/--tls-key for the
# client-facing HTTP API's own TLS identity (separate from the CA's own root;
# see docker/ca_service's TLS listener pattern for how to provision that
# pair), or --election-timeout-min-ms/--election-timeout-max-ms/
# --heartbeat-interval-ms to override Raft timing.
CA_CLUSTER_NODE_EXTRA_ARGS=
