{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "KythiraCaClusterNodeSecrets",
      "Effect": "Allow",
      "Action": ["secretsmanager:GetSecretValue"],
      "Resource": [
        "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:kythira/ca-cluster-node/auth-token*",
        "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:kythira/ca-cluster-node/unseal-key*"
      ]
    }
  ]
}
