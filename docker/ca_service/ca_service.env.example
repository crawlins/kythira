# Sample EnvironmentFile for ca_service.service. Copy to /etc/default/ca_service
# (mode 0600 — it holds a bearer-token secret) and fill in real values.

# Required — Requirement 11.4 (fail-closed bearer-token auth).
CA_SERVICE_AUTH_TOKEN=replace-with-a-long-random-token

# Required once fingerprint pinning is deployed alongside the token
# (Requirement 19.7) — the SHA-256 fingerprint of this server's root/issuing CA
# certificate, printed at startup or via `ca_service --print-root-fingerprint`.
# --tls-cert MUST point at a full leaf+root chain file, not a leaf-only
# certificate: fingerprint pinning targets the ROOT specifically (so a
# pinned value survives leaf rotation, Requirement 16), and the root only
# appears in what a client sees during the TLS handshake if the listener is
# configured to present its whole chain.
CA_SERVICE_ROOT_FINGERPRINT=

# "local" (default) or "aws-acm-pca".
CA_SERVICE_PROVIDER=local

# Only used when CA_SERVICE_PROVIDER=aws-acm-pca. AWS credentials themselves
# come from the instance's IAM role / default credentials provider chain, not
# from this file.
CA_SERVICE_ACM_PCA_ARN=
AWS_REGION=

# Rendered verbatim into ExecStart; used to pass --acm-pca-arn/--aws-region
# when CA_SERVICE_PROVIDER=aws-acm-pca, e.g.:
#   CA_SERVICE_EXTRA_ARGS=--acm-pca-arn ${CA_SERVICE_ACM_PCA_ARN} --aws-region ${AWS_REGION}
CA_SERVICE_EXTRA_ARGS=
