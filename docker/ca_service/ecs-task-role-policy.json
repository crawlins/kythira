{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "KythiraCaServiceAcmPca",
      "Effect": "Allow",
      "Action": [
        "acm-pca:GetCertificateAuthorityCertificate",
        "acm-pca:IssueCertificate",
        "acm-pca:GetCertificate"
      ],
      "Resource": "arn:aws:acm-pca:REGION:ACCOUNT_ID:certificate-authority/CA_ID"
    }
  ]
}
