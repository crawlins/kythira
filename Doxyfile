# Doxyfile — Doxygen configuration for Kythira
#
# Run:  doxygen Doxyfile          (from the repository root)
# Or:   cmake --build <builddir> --target docs
#
# Output lands in doxygen-output/html/index.html

#---------------------------------------------------------------------------
# Project identity
#---------------------------------------------------------------------------
PROJECT_NAME           = "Kythira"
PROJECT_BRIEF          = "Raft consensus library with pluggable transports and quorum management"
PROJECT_NUMBER         = 0.1.0
PROJECT_LOGO           =

#---------------------------------------------------------------------------
# Output
#---------------------------------------------------------------------------
OUTPUT_DIRECTORY       = doxygen-output
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp
# Exclude generated / backup / implementation-detail headers
EXCLUDE_PATTERNS       = *_impl*.hpp      \
                         *.hpp.backup      \
                         */examples/*

USE_MDFILE_AS_MAINPAGE = README.md

#---------------------------------------------------------------------------
# Source display
#---------------------------------------------------------------------------
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = include/
SHOW_USED_FILES        = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
EXTRACT_ANON_NSPACES   = NO
RESOLVE_UNNAMED_PARAMS = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

#---------------------------------------------------------------------------
# Documentation style
#---------------------------------------------------------------------------
# Treat the first sentence of a /// block as the @brief automatically
JAVADOC_AUTOBRIEF      = YES
JAVADOC_BANNER         = NO
QT_AUTOBRIEF           = NO

INHERIT_DOCS           = YES
SEPARATE_MEMBER_PAGES  = NO
TAB_SIZE               = 4

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_IF_INCOMPLETE_DOC = NO
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           =

#---------------------------------------------------------------------------
# Preprocessing — define optional-feature macros so those sections appear
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SKIP_FUNCTION_MACROS   = YES
PREDEFINED             = KYTHIRA_HAS_AWS_SDK  \
                         KYTHIRA_HAS_LDNS      \
                         KYTHIRA_HAS_POCO_DNSSD

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_HEADER            =
HTML_FOOTER            =
HTML_EXTRA_STYLESHEET  =
HTML_COLORSTYLE        = AUTO_LIGHT
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250
SEARCHENGINE           = YES

#---------------------------------------------------------------------------
# LaTeX, man pages, XML — all off
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_DOCBOOK       = NO

#---------------------------------------------------------------------------
# Graph / dot — off (no dot dependency in CI)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = NO

#---------------------------------------------------------------------------
# Sorting
#---------------------------------------------------------------------------
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = NO
SORT_BY_SCOPE_NAME     = NO
